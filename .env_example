# Copy this file to .env and replace the placeholder values.
# The app loads .env automatically when you run `python app/main.py`.
#
# Default date behavior:
# - If RUN_DATE_START and RUN_DATE_END are blank, the fetcher runs for yesterday.
# - CLI args override env dates, for example:
#   python app/main.py --start 2026-07-01 --end 2026-07-01

# Azure SQL / DWH
# Example server format: my-dwh-server.database.windows.net
SQL_SERVER=your-sql-server.database.windows.net
SQL_DATABASE=Datawarehouse
SQL_USERNAME=your-sql-username
SQL_PASSWORD=your-sql-password
SQL_DRIVER=ODBC Driver 17 for SQL Server

# Amazon SP-API / Login With Amazon
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.your-client-id
AMAZON_LWA_CLIENT_SECRET=your-lwa-client-secret
AMAZON_TITANCARDS_REFRESH_TOKEN=Atzr|your-refresh-token
AMAZON_TITANCARDS_SELLER_ID=your-seller-id

# Single-account config for TitanCards.
# The app reads the real secrets from the env vars above.
# Keep only the marketplaces you want enabled for the first local test.
AMAZON_ACCOUNTS_JSON=[{"account_id":1,"account_name":"TitanCards","seller_id_env":"AMAZON_TITANCARDS_SELLER_ID","refresh_token_env":"AMAZON_TITANCARDS_REFRESH_TOKEN","lwa_client_id_env":"AMAZON_LWA_CLIENT_ID","lwa_client_secret_env":"AMAZON_LWA_CLIENT_SECRET","marketplaces":["A1F83G8C2ARO7P"]}]

# Optional report request types.
# Leave blank for the first local run. Report requests are useful after base API sync works.
AMAZON_REPORT_TYPES=

# Local date window.
# Leave blank to run yesterday.
RUN_DATE_START=
RUN_DATE_END=

# First-run recommendation:
# 1. RUN_STEPS=sync_accounts,sync_marketplaces
# 2. Then try RUN_STEPS=ingest_orders
# 3. Leave blank to run all steps for yesterday.
RUN_STEPS=sync_accounts,sync_marketplaces

# Optional Slack summary webhook.
SLACK_WEBHOOK_URL=
